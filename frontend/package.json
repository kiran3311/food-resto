{
  "name": "food-order-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:electron": "tsc -p electron/tsconfig.json",
    "watch:electron": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "desktop:dev": "concurrently -k \"npm:watch:electron\" \"vite\" \"wait-on tcp:3000 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .\"",
    "desktop:build": "npm run build && npm run build:electron && electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.26.1",
    "recharts": "^2.12.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.1"
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.foodops.desktop",
    "productName": "FoodOps Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
